# Optional — tip / membership link shown in the footer (Ko-fi, Buy Me a Coffee, Patreon, etc.)
# PUBLIC_SUPPORT_URL=https://ko-fi.com/yourname

# Optional — Google AdSense publisher ID for auto ads (apply at https://www.google.com/adsense/)
# PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx

# Optional — show a one-line affiliate disclosure in the footer when you use affiliate links in posts
# PUBLIC_SHOW_AFFILIATE_DISCLOSURE=true

# Contact email — Privacy Policy & Impressum (defaults to privacy@haseebstudio.com if unset)
# PUBLIC_CONTACT_EMAIL=you@example.com

# Impressum (Germany / TMG) — required for a complete legal notice; set in Vercel before going live
# PUBLIC_IMPRESSUM_NAME=Your Full Name
# PUBLIC_IMPRESSUM_STREET=Musterstraße 1
# PUBLIC_IMPRESSUM_POSTAL_CODE=10115
# PUBLIC_IMPRESSUM_CITY=Berlin
# PUBLIC_IMPRESSUM_COUNTRY=Deutschland
# Optional:
# PUBLIC_IMPRESSUM_PHONE=+49 30 12345678
# PUBLIC_IMPRESSUM_VAT_ID=DE123456789
# PUBLIC_IMPRESSUM_BUSINESS_NOTE=Angaben zur Kleinunternehmerregelung etc., falls zutreffend
